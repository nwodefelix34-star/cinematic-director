
{
  "name": "cinematic-director",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev":     "vite",
    "build":   "vite build",
    "preview": "vite preview",

    "electron:dev":   "concurrently --kill-others \"vite\" \"wait-on http://localhost:5000 && cross-env NODE_ENV=development electron electron/main.cjs\"",
    "electron:build": "cross-env VITE_BUILD_TARGET=desktop vite build && electron-builder",

    "android":     "cross-env VITE_BUILD_TARGET=mobile vite build && npx cap sync android && npx cap open android",
    "ios":         "cross-env VITE_BUILD_TARGET=mobile vite build && npx cap sync ios && npx cap open ios",
    "mobile:sync": "cross-env VITE_BUILD_TARGET=mobile vite build && npx cap sync"
  },
  "build": {
    "appId": "com.cinematicdirector.app",
    "productName": "Cinematic Director",
    "directories": { "output": "dist-electron" },
    "files": ["dist/**/*", "electron/**/*", "node_modules/**/*"],
    "mac":   { "category": "public.app-category.video", "icon": "icon-512x512.png" },
    "win":   { "target": "nsis", "icon": "icon-512x512.png" },
    "linux": { "target": "AppImage", "icon": "icon-512x512.png" }
  },
  "dependencies": {
    "@google/genai":         "^1.40.0",
    "@google/generative-ai": "^0.24.1",
    "better-sqlite3":        "^12.6.2",
    "cors":                  "^2.8.6",
    "express":               "^4.18.2",
    "node-fetch":            "^3.3.2",
    "react":                 "^19.2.4",
    "react-dom":             "^19.2.4"
  },
  "devDependencies": {
    "@types/node":          "^22.14.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently":         "^8.2.2",
    "cross-env":            "^7.0.3",
    "electron":             "^32.0.0",
    "electron-builder":     "^24.13.3",
    "typescript":           "~5.8.2",
    "vite":                 "^5.2.10",
    "vite-plugin-pwa":      "^0.20.5",
    "wait-on":              "^7.2.0"
  },
  "optionalDependencies": {
    "@capacitor/android":                "^6.0.0",
    "@capacitor/browser":                "^6.0.0",
    "@capacitor/core":                   "^6.0.0",
    "@capacitor/ios":                    "^6.0.0",
    "@capacitor-community/inappbrowser": "^1.4.0",
    "@capacitor/cli":                    "^6.0.0"
  }
}
